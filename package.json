{
  "name": "obs-audio-monitor-assistant",
  "version": "3.3.0",
  "description": "OBS audio monitor assistant for livestream operators, focused on silent microphone alerts during live commerce and production workflows.",
  "author": "OBS 音频检测助手",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist/main/main/main.js && electron .\"",
    "start": "npm run build && electron .",
    "clean": "node scripts/clean.mjs",
    "icons": "electron scripts/render-icons.cjs",
    "build": "npm run clean && npm run typecheck && vite build && tsc -p tsconfig.main.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "package": "npm run build && electron-builder --dir",
    "package:win-portable": "npm run build && node scripts/package-win-portable.mjs",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac zip --arm64 --publish never"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "atem-connection": "^3.9.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "obs-websocket-js": "^5.0.8",
    "proxy-agent": "^6.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.obsaudioassistant.app",
    "productName": "OBS 音频检测助手",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Lin518-hub",
        "repo": "obs-audio-monitor-assistant"
      }
    ],
    "files": [
      "dist/**/*",
      "build/icon.*",
      "build/tray-*.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "OBS-Audio-Monitor-Assistant-Setup-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null,
      "artifactName": "OBS-Audio-Monitor-Assistant-${version}-${arch}.${ext}"
    },
    "nsis": {
      "guid": "com.obsaudioassistant.app",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OBS 音频检测助手",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "installerHeader": "build/installer-header.bmp",
      "include": "build/installer.nsh"
    }
  }
}
