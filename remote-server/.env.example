PORT=8088
PUBLIC_BASE_URL=http://192.168.110.111:8088
ADMIN_PASSWORD=replace-with-a-long-random-password
DATA_DIR=/data
UPDATE_DIR=/updates
UPDATE_SYNC_ENABLED=true
UPDATE_SYNC_INTERVAL_MS=120000
# Optional comma-separated mirror order. Defaults to GitHub Releases,
# ghproxy.net, then gh-proxy.com. The internal server downloads packages once;
# desktop clients continue to use the local cache first.
UPDATE_RELEASE_BASE_URLS=
# Optional bearer token used by the GitHub Actions post-release warm-up hook.
UPDATE_SYNC_TOKEN=
TLS_CERT_FILE=
TLS_KEY_FILE=
